# OpenAI 配置（保留兼容项）
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000

# DeepSeek 配置（用于替代 OpenAI）
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_API_URL=https://api.deepseek.example.com
DEEPSEEK_MODEL=deepseek-1
DEEPSEEK_TEMPERATURE=0.7
DEEPSEEK_MAX_TOKENS=2000

# Fusion 360 配置
FUSION_HOST=localhost
FUSION_PORT=8080
FUSION_TIMEOUT=30
FUSION_API_VERSION=2.0

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/fusion360_ai.log

# 应用配置
DEBUG_MODE=False
